em value=\"Events Only\"/>\r\n\t\t\t\t\t<dropdown-item value=\"Do Not Show\"/>\r\n\t\t\t\t</text>\r\n\t\t\t</group>\r\n\t\t\t<group collapsed=\"true\" identifier=\"contact\" label=\"Department Contact\">\r\n\t\t\t\t<shared-field field-id=\"ff6bcc12c0a81e5f43ef9b3716dc73ae\" identifier=\"display\" path=\"display\"/>\r\n\t\t\t\t<shared-field field-id=\"ff6bcc13c0a81e5f43ef9b372b9325fc\" identifier=\"bgColor\" path=\"background-color\"/>\r\n\t\t\t\t<asset field-id=\"ff6bcc13c0a81e5f43ef9b371856f88e\" help-text=\"Find department blocks under //_shared-content/departments/\" identifier=\"info\" label=\"Contact Block\" render-content-depth=\"2\" required=\"true\" type=\"block\"/>\r\n\t\t\t\t<text default=\"Yes\" field-id=\"ff6bcc13c0a81e5f43ef9b37a9565419\" identifier=\"show-department\" label=\"Show Department Name\" required=\"true\" type=\"radiobutton\">\r\n\t\t\t\t\t<radio-item value=\"Yes\"/>\r\n\t\t\t\t\t<radio-item value=\"No\"/>\r\n\t\t\t\t</text>\r\n\t\t\t\t<text default=\"Yes\" field-id=\"ff6bcc13c0a81e5f43ef9b3764f3e9e9\" identifier=\"show-phone\" label=\"Show Phone\" required=\"true\" type=\"radiobutton\">\r\n\t\t\t\t\t<radio-item value=\"Yes\"/>\r\n\t\t\t\t\t<radio-item value=\"No\"/>\r\n\t\t\t\t</text>\r\n\t\t\t\t<text default=\"Yes\" field-id=\"ff6bcc13c0a81e5f43ef9b370143ea91\" identifier=\"show-email\" label=\"Show Email\" required=\"true\" type=\"radiobutton\">\r\n\t\t\t\t\t<radio-item value=\"Yes\"/>\r\n\t\t\t\t\t<radio-item value=\"No\"/>\r\n\t\t\t\t</text>\r\n\t\t\t\t<text default=\"Yes\" field-id=\"ff6bcc13c0a81e5f43ef9b37d1736869\" identifier=\"show-hours\" label=\"Show Hours\" required=\"true\" type=\"radiobutton\">\r\n\t\t\t\t\t<radio-item value=\"Yes\"/>\r\n\t\t\t\t\t<radio-item value=\"No\"/>\r\n\t\t\t\t</text>\r\n\t\t\t\t<text default=\"Yes\" field-id=\"ff6bcc13c0a81e5f43ef9b37b43ba139\" identifier=\"show-address\" label=\"Show Address\" required=\"true\" type=\"radiobutton\">\r\n\t\t\t\t\t<radio-item value=\"Yes\"/>\r\n\t\t\t\t\t<radio-item va