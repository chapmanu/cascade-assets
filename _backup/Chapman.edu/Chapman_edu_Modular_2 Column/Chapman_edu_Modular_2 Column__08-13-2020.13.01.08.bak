{"dataDefinition"=>{"xml"=>"<system-data-structure>\r\n\t<group collapsed=\"true\" identifier=\"masthead\" label=\"Masthead Options\">\r\n\t\t<!-- Masthead Options -->\r\n\t\t<!-- radio-item show-fields map to groups below -->\r\n\t\t<!-- radio-item values map to Masthead format selectors -->\r\n\t\t<text field-id=\"ff6bcc10c0a81e5f43ef9b37a1878525\" help-text=\"these are the new wider mastheads available\" identifier=\"mastheadType\" label=\"Masthead Type\" type=\"radiobutton\">\r\n\t\t\t<radio-item show-fields=\"masthead/wide\" value=\"Wide\"/>\r\n\t\t\t<radio-item label=\"Narrow\" show-fields=\"masthead/branded201611\" value=\"Branded - New\"/>\r\n\t\t\t<radio-item label=\"Slider\" show-fields=\"masthead/slider201611\" value=\"Slider - New\"/>\r\n\t\t\t<radio-item show-fields=\"masthead/boxes\" value=\"Boxes\"/>\r\n\t\t\t<radio-item value=\"No Masthead\"/>\r\n\t\t</text>\r\n\t\t<!-- New masthead formats (Nov 2016): Branded and Slider -->\r\n\t\t<!-- These should mirror groups in three_column.xml -->\r\n\t\t<group identifier=\"wide\" label=\"Wide\">\r\n\t\t\t<text field-id=\"dbea3c9dc0a81e8a63fcf3c62c96537b\" help-text=\"title that appears in masthead to the side of the photo\" identifier=\"header\" label=\"School or Dept Name\" required=\"true\"/>\r\n\t\t\t<text field-id=\"dbea3c9ec0a81e8a63fcf3c6e247bd3b\" help-text=\"sub-title that appears bellow the title\" identifier=\"subTitle\" label=\"Subtitle\" required=\"false\"/>\r\n\t\t\t<asset field-id=\"dbea3c9ec0a81e8a63fcf3c66487fe1d\" identifier=\"image\" label=\"Image (780x260)\" required=\"true\" type=\"file\"/>\r\n\t\t\t<text field-id=\"dbea3c9ec0a81e8a63fcf3c6faa6d3ff\" help-text=\"Alternate text to describe image (required)\" identifier=\"altText\" label=\"Image Alt-Text\" required=\"true\"/>\r\n\t\t\t<text field-id=\"dbea3c9ec0a81e8a63fcf3c667582350\" help-text=\"short caption (70 chars max including blanks) to show on photo eg. Photo By: or other text\" identifier=\"photoCaption\" label=\"Caption (optional. 70 chars max)\" maxlength=\"70\"/>\r\n\t\t</group>\r\n\t\t<group identifier=\"branded201611\" label=\"Branded - New\">\r\n\t\t\t<text field-id=\"ff6bcc10c0a81e5f43ef9b372a08aebb\" help-text=\"title that appears in masthead to the side of the photo\" identifier=\"header\" label=\"School or Dept Name\" required=\"true\"/>\r\n\t\t\t<text field-id=\"dc06790ec0a81e8a63fcf3c683b7fd1f\" help-text=\"sub-title that appears bellow the title\" identifier=\"subTitle\" label=\"Subtitle\" required=\"false\"/>\r\n\t\t\t<asset field-id=\"ff6bcc10c0a81e5f43ef9b375578ff00\" identifier=\"image\" label=\"Image (780x260)\" required=\"true\" type=\"file\"/>\r\n\t\t\t<text field-id=\"ff6bcc10c0a81e5f43ef9b3763e6000f\" help-text=\"Alternate text to describe image (required)\" identifier=\"altText\" label=\"Image Alt-Text\" required=\"true\"/>\r\n\t\t\t<text field-id=\"ff6bcc10c0a81e5f43ef9b3719d59514\" help-text=\"short caption (70 chars max including blanks) to show on photo eg. Photo By: or other text\" identifier=\"photoCaption\" label=\"Caption (optional. 70 chars max)\" maxlength=\"70\"/>\r\n\t\t</group>\r\n\t\t<group identifier=\"slider201611\" label=\"Slider - New\">\r\n\t\t\t<text field-id=\"ff6bcc10c0a81e5f43ef9b378d9fe04c\" help-text=\"title that appears in masthead to the side of the photo\" identifier=\"header\" label=\"School or Dept Name\" required=\"true\"/>\r\n\t\t\t<group identifier=\"slides\" label=\"Slides\">\r\n\t\t\t\t<group identifier=\"slide\" label=\"Slide\" maximum-number=\"10\" minimum-number=\"1\" multiple=\"true\">\r\n\t\t\t\t\t<asset field-id=\"ff6bcc10c0a81e5f43ef9b37749b2253\" identifier=\"image\" label=\"Image (780x440)\" required=\"true\" type=\"file\"/>\r\n\t\t\t\t\t<text field-id=\"ff6bcc10c0a81e5f43ef9b370c79efab\" help-text=\"Alternate text to describe image (required)\" identifier=\"altText\" label=\"Image Alt-Text\" required=\"true\"/>\r\n\t\t\t\t\t<text field-id=\"ff6bcc10c0a81e5f43ef9b37067b215e\" identifier=\"subTitle\" label=\"subTitle\"/>\r\n\t\t\t\t\t<text field-id=\"ff6bcc10c0a81e5f43ef9b37d499bd69\" help-text=\"short caption (70 chars max including blanks) to show on photo eg. Photo By: or other text\" identifier=\"photoCaption\" label=\"Caption (optional. 70 chars max)\" maxlength=\"70\"/>\r\n\t\t\t\t</group>\r\n\t\t\t</group>\r\n\t\t</group>\r\n\t\t<group identifier=\"boxes\" label=\"Boxes\">\r\n\t\t\t<text default=\"No\" field-id=\"ff6bcc10c0a81e5f43ef9b377c6b6891\" identifier=\"show\" label=\"Show\" required=\"true\" type=\"radiobutton\">\r\n\t\t\t\t<radio-item value=\"Yes\"/>\r\n\t\t\t\t<radio-item value=\"No\"/>\r\n\t\t\t</text>\r\n\t\t\t<text field-id=\"ff6bcc10c0a81e5f43ef9b37123a8c5e\" identifier=\"autoRotate\" label=\"Auto Rotate\" type=\"checkbox\">\r\n\t\t\t\t<checkbox-item value=\"On\"/>\r\n\t\t\t</text>\r\n\t\t\t<text field-id=\"ff6bcc10c0a81e5f43ef9b37489c6b39\" help-text=\"Accepts an integer corresponding to slide number\" identifier=\"startingSlideNumber\" label=\"Starting Slide Number\"/>\r\n\t\t\t<text field-id=\"ff6bcc10c0a81e5f43ef9b37d850073b\" help-text=\"Number of seconds it takes a slide to auto rotate. If no value is entered, slides will rotate every ten seconds.\" identifier=\"speed\" label=\"Speed\"/>\r\n\t\t\t<group identifier=\"slides\" label=\"Slides\">\r\n\t\t\t\t<group identifier=\"slide\" label=\"Slide\" minimum-number=\"4\" multiple=\"true\">\r\n\t\t\t\t\t<asset field-id=\"ff6bcc11c0a81e5f43ef9b37f407f584\" identifier=\"image\" label=\"Image (266x220)\" type=\"file\"/>\r\n\t\t\t\t\t<text field-id=\"ff6bcc11c0a81e5f43ef9b3717dc1d6c\" help-text=\"Alternate text to describe image (required)\" identifier=\"altText\" label=\"Image Alt-Text\" required=\"true\"/>\r\n\t\t\t\t\t<text default=\"[header]\" field-id=\"ff6bcc11c0a81e5f43ef9b373fcbcb13\" identifier=\"header\" label=\"Header\" maxlength=\"35\" required=\"true\"/>\r\n\t\t\t\t\t<text default=\"[description]\" field-id=\"ff6bcc11c0a81e5f43ef9b37c999a99b\" identifier=\"description\" label=\"Description (25 words max)\" multi-line=\"true\" required=\"true\"/>\r\n\t\t\t\t\t<text field-id=\"ff6bcc11c0a81e5f43ef9b37c99b98f1\" help-text=\"full url (including http) to page outside of Cascade\" identifier=\"link\" label=\"External Link\"/>\r\n\t\t\t\t\t<asset field-id=\"ff6bcc11c0a81e5f43ef9b375cced7f1\" identifier=\"internalLink\" label=\"Or Internal Link\" type=\"page\"/>\r\n\t\t\t\t</group>\r\n\t\t\t</group>\r\n\t\t</group>\r\n\t</group>\r\n\t<group collapsed=\"true\" identifier=\"leftColumn\" label=\"Left Column\">\r\n\t\t<group identifier=\"widget\" label=\"Widget\" multiple=\"true\">\r\n\t\t\t<text default=\"(select one)\" field-id=\"ff6bcc11c0a81e5f43ef9b37111d5fbd\" help-text=\"Choose the type of content you'd like to add to the page\" identifier=\"widgetType\" label=\"Type of Widget\" type=\"dropdown\">\r\n\t\t\t\t<dropdown-item value=\"(select one)\"/>\r\n\t\t\t\t<dropdown-item show-fields=\"leftColumn/widget/actionButtons\" value=\"Button\"/>\r\n\t\t\t\t<dropdown-item show-fields=\"leftColumn/widget/calloutBox\" value=\"Callout Box\"/>\r\n\t\t\t\t<dropdown-item show-fields=\"leftColumn/widget/FeaturedNewsEvents\" value=\"Featured / News / Events\"/>\r\n\t\t\t\t<dropdown-item show-fields=\"leftColumn/widget/contact\" value=\"Department Contact Info\"/>\r\n\t\t\t\t<dropdown-item show-fields=\"leftColumn/widget/contact-profile-widget\" value=\"Contact Profile\"/>\r\n\t\t\t</text>\r\n\t\t\t<group collapsed=\"true\" identifier=\"calloutBox\" label=\"Callout Box\">\r\n\t\t\t\t<text default=\"Yes\" field-id=\"ff6bcc11c0a81e5f43ef9b37198ccc56\" identifier=\"display-callout-box\" label=\"Show\" type=\"radiobutton\">\r\n\t\t\t\t\t<radio-item value=\"Yes\"/>\r\n\t\t\t\t\t<radio-item value=\"No\"/>\r\n\t\t\t\t</text>\r\n\t\t\t\t<text default=\"Grey\" field-id=\"ff6bcc11c0a81e5f43ef9b37915b8858\" identifier=\"color-value\" label=\"Color\" type=\"dropdown\">\r\n\t\t\t\t\t<dropdown-item value=\"Grey\"/>\r\n\t\t\t\t\t<dropdown-item value=\"Red\"/>\r\n\t\t\t\t\t<dropdown-item value=\"Black\"/>\r\n\t\t\t\t\t<dropdown-item value=\"Sand\"/>\r\n\t\t\t\t\t<dropdown-item value=\"White\"/>\r\n\t\t\t\t</text>\r\n\t\t\t\t<group identifier=\"text\" label=\"Text\">\r\n\t\t\t\t\t<text field-id=\"ff6bcc11c0a81e5f43ef9b37c8336f33\" help-text=\"Preheader\" identifier=\"preheader\" label=\"Preheader (Optional)\"/>\r\n\t\t\t\t\t<text field-id=\"ff6bcc11c0a81e5f43ef9b37d3a1e19f\" help-text=\"Headline\" identifier=\"headline\" label=\"Headline\" multi-line=\"true\"/>\r\n\t\t\t\t\t<text field-id=\"ff6bcc11c0a81e5f43ef9b378ac607c9\" identifier=\"copy\" label=\"Copy\" wysiwyg=\"true\"/>\r\n\t\t\t\t</group>\r\n\t\t\t\t<group identifier=\"links\" label=\"Links\">\r\n\t\t\t\t\t<group identifier=\"link\" label=\"Link\" multiple=\"true\">\r\n\t\t\t\t\t\t<text default=\"Internal Link\" field-id=\"ff6bcc11c0a81e5f43ef9b3713ff39e2\" identifier=\"linkType\" label=\"Link Type\" type=\"radiobutton\">\r\n\t\t\t\t\t\t\t<radio-item show-fields=\"leftColumn/widget/calloutBox/links/link/internalLink\" value=\"Internal Link\"/>\r\n\t\t\t\t\t\t\t<radio-item show-fields=\"leftColumn/widget/calloutBox/links/link/externalLink\" value=\"External Link\"/>\r\n\t\t\t\t\t\t\t<radio-item show-fields=\"leftColumn/widget/calloutBox/links/link/fileLink\" value=\"File Link\"/>\r\n\t\t\t\t\t\t</text>\r\n\t\t\t\t\t\t<text field-id=\"ff6bcc11c0a81e5f43ef9b3727ad4801\" identifier=\"externalLink\" label=\"External Link\"/>\r\n\t\t\t\t\t\t<asset field-id=\"ff6bcc11c0a81e5f43ef9b37f385eb22\" identifier=\"internalLink\" label=\"Internal Link\" type=\"page\"/>\r\n\t\t\t\t\t\t<asset field-id=\"ff6bcc11c0a81e5f43ef9b37688225c2\" identifier=\"fileLink\" label=\"File Link\" type=\"file\"/>\r\n\t\t\t\t\t\t<text field-id=\"ff6bcc11c0a81e5f43ef9b377cc881e0\" identifier=\"label\" label=\"Label\"/>\r\n\t\t\t\t\t</group>\r\n\t\t\t\t</group>\r\n\t\t\t</group>\r\n\t\t\t<group collapsed=\"true\" identifier=\"contact-profile-widget\" label=\"Contact Profile\" multiple=\"true\">\r\n\t\t\t\t<shared-field field-id=\"ff6bcc12c0a81e5f