\n\t\t\t\t\t<dropdown-item value=\"Featured - News (News active)\"/>\r\n\t\t\t\t\t<dropdown-item value=\"Featured - Events (Featured active)\"/>\r\n\t\t\t\t\t<dropdown-item value=\"Featured - Events (Events active)\"/>\r\n\t\t\t\t\t<dropdown-item value=\"News - Events (News active)\"/>\r\n\t\t\t\t\t<dropdown-item value=\"News - Events (Events active)\"/>\r\n\t\t\t\t\t<dropdown-item value=\"Featured Only\"/>\r\n\t\t\t\t\t<dropdown-item value=\"News Only\"/>\r\n\t\t\t\t\t<dropdown-item value=\"Events Only\"/>\r\n\t\t\t\t\t<dropdown-item value=\"Do Not Show\"/>\r\n\t\t\t\t</text>\r\n\t\t\t</group>\r\n\t\t\t<group collapsed=\"true\" identifier=\"contact\" label=\"Department Contact\">\r\n\t\t\t\t<shared-field field-id=\"ff6bcc3bc0a81e5f43ef9b3700b3042d\" identifier=\"display\" path=\"display\"/>\r\n\t\t\t\t<shared-field field-id=\"ff6bcc3bc0a81e5f43ef9b37ca9f71c8\" identifier=\"bgColor\" path=\"background-color\"/>\r\n\t\t\t\t<asset field-id=\"ff6bcc3bc0a81e5f43ef9b37b757c757\" help-text=\"Find department blocks under //_shared-content/departments/\" identifier=\"info\" label=\"Contact Block\" render-content-depth=\"2\" required=\"true\" type=\"block\"/>\r\n\t\t\t\t<text default=\"Yes\" field-id=\"ff6bcc3bc0a81e5f43ef9b3787d8d425\" identifier=\"show-department\" label=\"Show Department Name\" required=\"true\" type=\"radiobutton\">\r\n\t\t\t\t\t<radio-item value=\"Yes\"/>\r\n\t\t\t\t\t<radio-item value=\"No\"/>\r\n\t\t\t\t</text>\r\n\t\t\t\t<text default=\"Yes\" field-id=\"ff6bcc3bc0a81e5f43ef9b37b0f34d1c\" identifier=\"show-phone\" label=\"Show Phone\" required=\"true\" type=\"radiobutton\">\r\n\t\t\t\t\t<radio-item value=\"Yes\"/>\r\n\t\t\t\t\t<radio-item value=\"No\"/>\r\n\t\t\t\t</text>\r\n\t\t\t\t<text default=\"Yes\" field-id=\"ff6bcc3bc0a81e5f43ef9b37194ae712\" identifier=\"show-email\" label=\"Show Email\" required=\"true\" type=\"radiobutton\">\r\n\t\t\t\t\t<radio-item value=\"Yes\"/>\r\n\t\t\t\t\t<radio-item value=\"No\"/>\r\n\t\t\t\t</text>\r\n\t\t\t\t<text d