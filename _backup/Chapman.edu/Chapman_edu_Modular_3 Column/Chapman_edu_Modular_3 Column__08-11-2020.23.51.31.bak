{"dataDefinition"=>{"xml"=>"<system-data-structure>\r\n\t<group collapsed=\"true\" identifier=\"masthead\" label=\"Masthead Options\">\r\n\t\t<!-- Masthead Options -->\r\n\t\t<!-- radio-item show-fields map to groups below -->\r\n\t\t<!-- radio-item values map to Masthead format selectors -->\r\n\t\t<text field-id=\"ff6bcc38c0a81e5f43ef9b37ac5ffc0b\" help-text=\"these are the new wider mastheads available\" identifier=\"mastheadType\" label=\"Masthead Type\" type=\"radiobutton\">\r\n\t\t\t<radio-item show-fields=\"masthead/branded201611\" value=\"Branded - New\"/>\r\n\t\t\t<radio-item show-fields=\"masthead/slider201611\" value=\"Slider - New\"/>\r\n\t\t\t<radio-item show-fields=\"masthead/boxes\" value=\"Boxes\"/>\r\n\t\t\t<radio-item value=\"No Masthead\"/>\r\n\t\t</text>\r\n\t\t<!-- New masthead formats (Nov 2016): Branded and Slider -->\r\n\t\t<!-- These should mirror groups in two_column.xml -->\r\n\t\t<group identifier=\"branded201611\" label=\"Branded - New\">\r\n\t\t\t<text field-id=\"ff6bcc38c0a81e5f43ef9b378d8025a9\" help-text=\"title that appears in masthead to the side of the photo\" identifier=\"header\" label=\"School or Dept Name\" required=\"true\"/>\r\n\t\t\t<asset field-id=\"ff6bcc38c0a81e5f43ef9b37f2d6e2db\" identifier=\"image\" label=\"Image (780x260)\" required=\"true\" type=\"file\"/>\r\n\t\t\t<text field-id=\"ff6bcc38c0a81e5f43ef9b37eefb31a6\" help-text=\"Alternate text to describe image (required)\" identifier=\"altText\" label=\"Image Alt-Text\" required=\"true\"/>\r\n\t\t\t<text field-id=\"ff6bcc38c0a81e5f43ef9b37c15820ad\" help-text=\"short caption (70 chars max including blanks) to show on photo eg. Photo By: or other text\" identifier=\"photoCaption\" label=\"Caption (optional. 70 chars max)\" maxlength=\"70\"/>\r\n\t\t</group>\r\n\t\t<group identifier=\"slider201611\" label=\"Slider - New\">\r\n\t\t\t<text field-id=\"ff6bcc38c0a81e5f43ef9b37b872a571\" help-text=\"title that appears in masthead to the side of the photo\" identifier=\"header\" label=\"School or Dept Name\" required=\"true\"/>\r\n\t\t\t<group identifier=\"slides\" label=\"Slides\">\r\n\t\t\t\t<group identifier=\"slide\" label=\"Slide\" maximum-number=\"10\" minimum-number=\"1\" multiple=\"true\">\r\n\t\t\t\t\t<asset field-id=\"ff6bcc38c0a81e5f43ef9b3769d98c08\" identifier=\"image\" label=\"Image (780x440)\" required=\"true\" type=\"file\"/>\r\n\t\t\t\t\t<text field-id=\"ff6bcc38c0a81e5f43ef9b37450ef255\" help-text=\"Alternate text to describe image (required)\" identifier=\"altText\" label=\"Image Alt-Text\" required=\"true\"/>\r\n\t\t\t\t\t<text field-id=\"ff6bcc38c0a81e5f43ef9b378142265a\" identifier=\"subTitle\" label=\"subTitle\"/>\r\n\t\t\t\t\t<text field-id=\"ff6bcc38c0a81e5f43ef9b37715fd868\" help-text=\"short caption (70 chars max including blanks) to show on photo eg. Photo By: or other text\" identifier=\"photoCaption\" label=\"Caption (optional. 70 chars max)\" maxlength=\"70\"/>\r\n\t\t\t\t</group>\r\n\t\t\t</group>\r\n\t\t</group>\r\n\t\t<group identifier=\"boxes\" label=\"Boxes\">\r\n\t\t\t<text default=\"No\" field-id=\"ff6bcc38c0a81e5f43ef9b37fe74fb5e\" identifier=\"show\" label=\"Show\" required=\"true\" type=\"radiobutton\">\r\n\t\t\t\t<radio-item value=\"Yes\"/>\r\n\t\t\t\t<radio-item value=\"No\"/>\r\n\t\t\t</text>\r\n\t\t\t<text field-id=\"ff6bcc38c0a81e5f43ef9b374c2dcf37\" identifier=\"autoRotate\" label=\"Auto Rotate\" type=\"checkbox\">\r\n\t\t\t\t<checkbox-item value=\"On\"/>\r\n\t\t\t</text>\r\n\t\t\t<text field-id=\"ff6bcc38c0a81e5f43ef9b37e508e25b\" help-text=\"Accepts an integer corresponding to slide number\" identifier=\"startingSlideNumber\" label=\"Starting Slide Number\"/>\r\n\t\t\t<text field-id=\"ff6bcc38c0a81e5f43ef9b3768b6e758\" help-text=\"Number of seconds it takes a slide to auto rotate. If no value is entered, slides will rotate every ten seconds.\" identifier=\"speed\" label=\"Speed\"/>\r\n\t\t\t<group identifier=\"slides\" label=\"Slides\">\r\n\t\t\t\t<group identifier=\"slide\" label=\"Slide\" minimum-number=\"4\" multiple=\"true\">\r\n\t\t\t\t\t<asset field-id=\"ff6bcc38c0a81e5f43ef9b37f7cc8bfb\" identifier=\"image\" label=\"Image (266x220)\" type=\"file\"/>\r\n\t\t\t\t\t<text field-id=\"ff6bcc39c0a81e5f43ef9b3744f25a60\" help-text=\"Alternate text to describe image (required)\" identifier=\"altText\" label=\"Image Alt-Text\" required=\"true\"/>\r\n\t\t\t\t\t<text default=\"[header]\" field-id=\"ff6bcc39c0a81e5f43ef9b37edf0cca4\" identifier=\"header\" label=\"Header\" maxlength=\"35\" required=\"true\"/>\r\n\t\t\t\t\t<text default=\"[description]\" field-id=\"ff6bcc39c0a81e5f43ef9b37fb8cd0ed\" identifier=\"description\" label=\"Description (25 words max)\" multi-line=\"true\" required=\"true\"/>\r\n\t\t\t\t\t<text field-id=\"ff6bcc39c0a81e5f43ef9b3713c0fd0c\" help-text=\"full url (including http) to page outside of Cascade\" identifier=\"link\" label=\"External Link\"/>\r\n\t\t\t\t\t<asset field-id=\"ff6bcc39c0a81e5f43ef9b37f4d0a62c\" identifier=\"internalLink\" label=\"Or Internal Link\" type=\"page\"/>\r\n\t\t\t\t</group>\r\n\t\t\t</group>\r\n\t\t</group>\r\n\t</group>\r\n\t<group collapsed=\"true\" identifier=\"leftColumn\" label=\"Left Column\">\r\n\t\t<group identifier=\"widget\" label=\"Widget\" multiple=\"true\">\r\n\t\t\t<text default=\"(select one)\" field-id=\"ff6bcc39c0a81e5f43ef9b37519a4a68\" help-text=\"Choose the type of content you'd like to add to the page\" identifier=\"widgetType\" label=\"Type of Widget\" type=\"dropdown\">\r\n\t\t\t\t<dropdown-item value=\"(select one)\"/>\r\n\t\t\t\t<dropdown-item show-fields=\"leftColumn/widget/actionButtons\" value=\"Button\"/>\r\n\t\t\t\t<dropdown-item show-fields=\"leftColumn/widget/calloutBox\" value=\"Callout Box\"/>\r\n\t\t\t\t<dropdown-item show-fields=\"leftColumn/widget/FeaturedNewsEvents\" value=\"Featured / News / Events\"/>\r\n\t\t\t\t<dropdown-item show-fields=\"leftColumn/widget/contact-profile-widget\" value=\"Contact Profile\"/>\r\n\t\t\t\t<dropdown-item show-fields=\"leftColumn/widget/contact\" value=\"Department Contact Info\"/>\r\n\t\t\t</text>\r\n\t\t\t<group collapsed=\"true\" identifier=\"contact-profile-widget\" label=\"Contact Profile\">\r\n\t\t\t\t<shared-field field-id=\"ff6bcc39c0a81e5f43ef9b37182a10fe\" identifier=\"display\" path=\"display\"/>\r\n\t\t\t\t<shared-field field-id=\"ff6bcc39c0a81e5f43ef9b37558a08ef\" identifier=\"bgColor\" path=\"background-color\"/>\r\n\t\t\t\t<shared-field field-id=\"ff6bcc39c0a81e5f43ef9b376d4e9ee4\" identifier=\"image\" path=\"image\" required=\"true\"/>\r\n\t\t\t\t<text field-id=\"ff6bcc39c0a81e5f43ef9b37fab117ce\" identifier=\"heading\" label=\"Heading\" maxlength=\"100\" required=\"true\"/>\r\n\t\t\t\t<text field-id=\"ff6bcc39c0a81e5f43ef9b37ed837f91\" identifier=\"name\" label=\"Name\" maxlength=\"50\" required=\"true\"/>\r\n\t\t\t\t<text field-id=\"ff6bcc39c0a81e5f43ef9b37d6b8709a\" identifier=\"dept\" label=\"Department\" maxlength=\"100\"/>\r\n\t\t\t\t<text field-id=\"ff6bcc39c0a81e5f43ef9b375e658295\" identifier=\"phone\" label=\"Phone\"/>\r\n\t\t\t\t<text field-id=\"ff6bcc39c0a81e5f43ef9b37bddc5fc2\" identifier=\"email\" label=\"Email\"/>\r\n\t\t\t</group>\r\n\t\t\t<group collapsed=\"true\" identifier=\"calloutBox\" label=\"Callout Box\">\r\n\t\t\t\t<text default=\"Yes\" field-id=\"ff6bcc39c0a81e5f43ef9b37ce1a1fbf\" identifier=\"display-callout-box\" label=\"Show\" type=\"radiobutton\">\r\n\t\t\t\t\t<radio-item value=\"Yes\"/>\r\n\t\t\t\t\t<radio-item value=\"No\"/>\r\n\t\t\t\t</text>\r\n\t\t\t\t<text default=\"Grey\" field-id=\"ff6bcc39c0a81e5f43ef9b3775f1572c\" identifier=\"color-value\" label=\"Color\" type=\"dropdown\">\r\n\t\t\t\t\t<dropdown-item value=\"Grey\"/>\r\n\t\t\t\t\t<dropdown-item value=\"Red\"/>\r\n\t\t\t\t\t<dropdown-item value=\"Black\"/>\r\n\t\t\t\t\t<dropdown-item value=\"Sand\"/>\r\n\t\t\t\t\t<dropdown-item value=\"White\"/>\r\n\t\t\t\t</text>\r\n\t\t\t\t<group identifier=\"text\" label=\"Text\">\r\n\t\t\t\t\t<text field-id=\"ff6bcc39c0a81e5f43ef9b379124f9c2\" help-text=\"Preheader\" identifier=\"preheader\" label=\"Preheader (Optional)\"/>\r\n\t\t\t\t\t<text field-id=\"ff6bcc3ac0a81e5f43ef9b378b4739c8\" help-text=\"Headline\" identifier=\"headline\" label=\"Headline\" multi-line=\"true\"/>\r\n\t\t\t\t\t<text field-id=\"ff6bcc3ac0a81e5f43ef9b37b7df7e3c\" identifier=\"copy\" label=\"Copy\" wysiwyg=\"true\"/>\r\n\t\t\t\t</group>\r\n\t\t\t\t<group identifier=\"links\" label=\"Links\">\r\n\t\t\t\t\t<group identifier=\"link\" label=\"Link\" multiple=\"true\">\r\n\t\t\t\t\t\t<text default=\"Internal Link\" field-id=\"ff6bcc3ac0a81e5f43ef9b3790063d26\" identifier=\"linkType\" label=\"Link Type\" type=\"radiobutton\">\r\n\t\t\t\t\t\t\t<radio-item show-fields=\"leftColumn/widget/calloutBox/links/link/internalLink\" value=\"Internal Link\"/>\r\n\t\t\t\t\t\t\t<radio-item show-fields=\"leftColumn/widget/calloutBox/links/link/externalLink\" value=\"External Link\"/>\r\n\t\t\t\t\t\t\t<radio-item show-fields=\"leftColumn/widget/calloutBox/links/link/fileLink\" value=\"File Link\"/>\r\n\t\t\t\t\t\t</text>\r\n\t\t\t\t\t\t<text field-id=\"ff6bcc3ac0a81e5f43ef9b3718425d99\" identifier=\"externalLink\" label=\"External Link\"/>\r\n\t\t\t\t\t\t<asset field-id=\"ff6bcc3ac0a81e5f43ef9b378049cba9\" identifier=\"internalLink\" label=\"Internal Link\" type=\"page\"/>\r\n\t\t\t\t\t\t<asset field-id=\"ff6bcc3ac0a81e5f43ef9b37d26aa4b3\" identifier=\"fileLink\" label=\"File Link\" type=\"file\"/>\r\n\t\t\t\t\t\t<text field-id=\"ff6bcc3ac0a81e5f43ef9b37120bf999\" identifier=\"label\" label=\"Label\"/>\r\n\t\t\t\t\t</group>\r\n\t\t\t\t</group>\r\n\t\t\t</group>\r\n\t\t\t<group collapsed=\"true\" identifier=\"actionButtons\" label=\"Buttons\">\r\n\t\t\t\t<text default=\"Yes\" field-id=\"ff6bcc3ac0a81e5f43ef9b37e235e5bf\" identifier=\"display-action-buttons\" label=\"Show\" type=\"radiobutton\">\r\n\t\t\t\t\t<radio-item value=\"Yes\"/>\r\n\t\t\t\t\t<radio-item value=\"No\"/>\r\n\t\t\t\t</text>\r\n\t\t\t\t<group identifier=\"button\" label=\"Button\" multiple